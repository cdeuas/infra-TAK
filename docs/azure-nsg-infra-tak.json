{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "nsgName": {
      "type": "string",
      "defaultValue": "tak-test-1-nsg",
      "metadata": {
        "description": "Name of the existing NSG to update"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "adminSourceIP": {
      "type": "string",
      "defaultValue": "*",
      "metadata": {
        "description": "Your public IP address in CIDR notation (e.g. 1.2.3.4/32) for SSH and console access. Use * to allow any (not recommended for production)."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-04-01",
      "name": "[parameters('nsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "SSH",
            "properties": {
              "priority": 100,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "[parameters('adminSourceIP')]",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "22",
              "description": "SSH - restricted to admin IP"
            }
          },
          {
            "name": "HTTP",
            "properties": {
              "priority": 110,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "80",
              "description": "HTTP - redirects to HTTPS via Caddy"
            }
          },
          {
            "name": "HTTPS",
            "properties": {
              "priority": 120,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "443",
              "description": "HTTPS - all web services via Caddy"
            }
          },
          {
            "name": "infra-TAK-console",
            "properties": {
              "priority": 130,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "[parameters('adminSourceIP')]",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "5001",
              "description": "infra-TAK management console"
            }
          },
          {
            "name": "TAK-clients",
            "properties": {
              "priority": 140,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8089",
              "description": "TAK Server - ATAK/WinTAK/iTAK client connections (TLS)"
            }
          },
          {
            "name": "TAK-admin-cert",
            "properties": {
              "priority": 150,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8443",
              "description": "TAK Server admin - certificate auth"
            }
          },
          {
            "name": "TAK-admin-ldap",
            "properties": {
              "priority": 160,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8446",
              "description": "TAK Server admin - LDAP/password auth"
            }
          },
          {
            "name": "RTSP",
            "properties": {
              "priority": 170,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8554",
              "description": "MediaMTX - RTSP drone video stream"
            }
          },
          {
            "name": "WebRTC-HLS",
            "properties": {
              "priority": 180,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8889",
              "description": "MediaMTX - WebRTC/HLS video playback"
            }
          },
          {
            "name": "WebRTC-signal",
            "properties": {
              "priority": 190,
              "protocol": "Udp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8189",
              "description": "MediaMTX - WebRTC signaling"
            }
          },
          {
            "name": "RTP-media",
            "properties": {
              "priority": 200,
              "protocol": "Udp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "9000-9100",
              "description": "MediaMTX - WebRTC RTP media ports"
            }
          },
          {
            "name": "MediaMTX-web-editor",
            "properties": {
              "priority": 210,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "[parameters('adminSourceIP')]",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "5080",
              "description": "MediaMTX web editor - admin only"
            }
          },
          {
            "name": "TAK-Server-plaintext-disabled",
            "properties": {
              "priority": 220,
              "protocol": "Tcp",
              "access": "Deny",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8087",
              "description": "TAK Server plaintext port - disabled by default, deny explicitly"
            }
          }
        ]
      }
    }
  ]
}
